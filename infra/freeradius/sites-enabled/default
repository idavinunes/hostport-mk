server default {
  listen {
    type = auth
    ipaddr = *
    port = 1812
  }

  listen {
    type = acct
    ipaddr = *
    port = 1813
  }

  authorize {
    preprocess
    suffix
    sql
    pap
  }

  authenticate {
    Auth-Type PAP {
      pap
    }
  }

  preacct {
    preprocess
    acct_unique
    suffix
  }

  accounting {
    sql
  }

  session {
    sql
  }

  post-auth {
    sql
  }
}

